OPENAI_API_KEY=sk-proj
NVIDIA_API_KEY=
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
#NVIDIA_API_KEY_4=
HF_TOKEN=
# Optional. Paste a Tavily API key here (free tier: 1000 searches/month) to
# upgrade the Research Agent's web search quality. If left blank, the
# Research Agent falls back to DuckDuckGo (no key required) and then to
# curated fixtures. Get a key at https://tavily.com/
TAVILY_API_KEY=

# /planner slash-command. The planner-first pipeline (src.core.pipeline)
# is reachable in code via "/planner <query>" but the panel-slice
# factories (us_stock, indian_stock, portfolio, panel) aren't shipped
# yet — any /planner query that needs them crashes. Default: 0 (hidden
# from end users). Set to 1 to expose; useful for internal demos of
# the new architecture.
FINAI_PLANNER_PREFIX=0

# Verbose dev-trace classification card. Default: 0 (hidden in
# production). Set to 1 to always surface the routing card; or use
# "/trace <query>" on a single message for one-shot diagnostics.
FINAI_VERBOSE_TRACE=0